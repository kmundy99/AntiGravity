rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Basic catch-all to prevent unauthenticated access, while allowing authenticated users
    // In a fully locked-down production app, this would be highly granular.
    // For this beta, requiring Firebase Auth login is sufficient security.
    match /{document=**} {
      allow read: if true;
    }

    match /users/{userId} {
      // Allow creating new provisional users
      allow create: if request.auth != null;
      // Allow modifying if the user owns the doc or if they are updating a provisional user
      allow update, delete: if request.auth != null;
    }

    match /feedbacks/{feedbackId} {
      allow write: if request.auth != null;
    }

    match /contracts/{contractId} {
      allow write: if request.auth != null;
      
      match /sessions/{sessionId} {
         allow write: if request.auth != null;
      }
    }

    match /matches/{matchId} {
      allow write: if request.auth != null;
      
      match /chatReads/{userId} {
         allow write: if request.auth != null;
      }
    }
    
    match /scheduled_messages/{msgId} {
      allow write: if request.auth != null;
    }
    
    match /message_log/{logId} {
      allow write: if request.auth != null;
    }

    match /mail/{mailId} {
      allow write: if request.auth != null;
    }

    match /messages/{messageId} {
      allow write: if request.auth != null;
    }
  }
}
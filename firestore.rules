rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Basic catch-all to prevent unauthenticated access, while allowing authenticated users
    // In a fully locked-down production app, this would be highly granular.
    // For this beta, requiring Firebase Auth login is sufficient security.
    match /{document=**} {
      allow read: if request.auth != null;
    }

    match /users/{userId} {
      // Users can modify their own doc if their auth.uid is mapped to it
      allow write: if request.auth != null && 
                   request.auth.uid in request.resource.data.auth_uids;
    }

    match /contracts/{contractId} {
      allow write: if request.auth != null;
      
      match /sessions/{sessionId} {
         allow write: if request.auth != null;
      }
    }

    match /matches/{matchId} {
      allow write: if request.auth != null;
      
      match /chatReads/{userId} {
         allow write: if request.auth != null;
      }
    }
    
    match /scheduled_messages/{msgId} {
      allow write: if request.auth != null;
    }
    
    match /message_log/{logId} {
      allow write: if request.auth != null;
    }
  }
}